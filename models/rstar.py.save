import pandas as pd
import json

def generate_html_paper():
    diag_df = pd.read_csv("output/tables/diagnostico_2024.csv")
    stoc_df = pd.read_csv("output/tables/stochastic_summary.csv")
    merged = diag_df.merge(stoc_df, left_on="Pais", right_on="country", how="left")

    html = """<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Modelo de Viabilidade Fiscal Austríaca (MVFA)</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css">
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/contrib/auto-render.min.js" onload="renderMathInElement(document.body);"></script>
    <style>
        body { font-family: "Palatino Linotype", "Book Antiqua", Palatino, serif; line-height: 1.6; color: #333; max-width: 900px; margin: 0 auto; padding: 2rem; background-color: #fdfdfd; }
        h1, h2, h3, h4 { color: #111; }
        h1 { text-align: center; font-size: 1.8em; margin-bottom: 0.5rem; }
        .author-date { text-align: center; margin-bottom: 2rem; font-style: italic; color: #555; }
        .abstract { font-size: 0.95em; padding: 1rem; background-color: #f4f4f4; border-left: 4px solid #444; margin-bottom: 2rem; }
        table { width: 100%; border-collapse: collapse; margin: 2rem 0; font-size: 0.9em; }
        th, td { border: 1px solid #ddd; padding: 8px; text-align: center; }
        th { background-color: #eee; font-weight: bold; }
        img { max-width: 100%; display: block; margin: 2rem auto; border: 1px solid #ddd; }
        .insustentavel { color: #b91c1c; font-weight: bold; }
        .sustentavel { color: #15803d; font-weight: bold; }
        .limiar { color: #ca8a04; font-weight: bold; }
    </style>
</head>
<body>
    <h1>Modelo de Viabilidade Fiscal Austríaca: Uma Análise Estocástica de Restrições Monetárias e Dívida Soberana</h1>
    <div class="author-date">Research Paper — Abril 2026</div>
    <div class="abstract">
        <strong>Resumo:</strong> Este projeto apresenta o Modelo de Viabilidade Fiscal Austríaca (MVFA), um framework econométrico e contábil focado na sustentabilidade da dívida fiduciária. O método emprega Vetores Autorregressivos (VAR) combinados à simulação de Monte Carlo para avaliar a probabilidade de insolvência ou dominância fiscal explícita, controlando distorções de preferências intertemporais através do Gap de Wicksell e da Expansão Monetária Austríaca (EMA). 
    </div>

    <h2>1. Revisão de Literatura</h2>
    <p>A abordagem de sustentabilidade da dívida tem sido predominantemente explorada por modelos como o <i>Debt Sustainability Analysis</i> (DSA) do FMI. Tais modelos geralmente confiam em expectativas de consolidação fiscal gradual (ajustes em $t+k$ que nunca divergem perpetuamente). No entanto, de acordo com as restrições indicadas por Nadal De Simone (2024), abordagens ortodoxas subestimam o custo irreversível das alocações enviesadas induzidas por bancos centrais. Para calibrar a taxa natural de juros, recorremos primariamente à tradição estabelecida por Holston-Laubach-Williams, mas expandindo o escopo via FAVAR (<i>Factor-Augmented VAR</i>) e Filtro Hodrick-Prescott para assegurar maior solidez metodológica em economias com quebra estrutural.</p>

    <h2>2. Dados e Fontes</h2>
    <p>O painel de dados cobre as principais economias avançadas e emergentes. Variáveis como PIB Nominal e Deflator provêm do FMI (World Economic Outlook). Séries monetárias mais sensíveis como M2 e as <i>Policy Rates</i> emendam dados do Banco de Compensações Internacionais (BIS) com do <i>World Bank</i>.</p>
    <ul>
        <li><strong>Valores Não Disponíveis (N/A):</strong> Variáveis cuja coleta oficial foi suspensa, redefinida de maneira letal (como o recálculo expansivo de agregados M) ou não reportadas regionalmente são denotadas como N/A e suprimidas nos sub-índices de pontuação, evitando extrapolações sintéticas vazias.</li>
    </ul>

    <h2>3. Especificação Econométrica</h2>
    <p>Para gerar projeções da dívida soberana sobre o PIB ($b_t$), definimos o VAR(p) na forma reduzida para a matriz de variáveis endógenas (Crescimento Real, Deflator, Taxa Nominal de 10 anos, e Balanço Primário). A ordem de defasagem (lags) é determinada via parcimônia de acordo com o tamanho amostral longitudinal — essencialmente 1 lag para séries curtas, ou 2 para matriz completa, evitando sobre-parametrização (<i>overfitting</i>) antes de submeter ao fator de correlação da distribuição normal nas projeções de Monte Carlo.</p>

    <h2>4. Resultados e Avaliação da Amostra</h2>
    <p>A tabela resume os parâmetros de insustentabilidade.</p>
    <table>
        <thead>
            <tr>
                <th>País</th>
                <th>Gap Domar</th>
                <th>ΔW (Wicksell)</th>
                <th>EMA (%)</th>
                <th>ISF (%)</th>
                <th>IDEC</th>
                <th>Status Qualitativo</th>
                <th>Risco VAR (5y)</th>
            </tr>
        </thead>
        <tbody>
"""
    for _, row in merged.iterrows():
        gap = f"{row['GAP_Domar']:.2f}" if pd.notna(row['GAP_Domar']) else "N/A*"
        
        # Explain Argentina explicitly if Gap is extreme
        if row['Pais'] == "Argentina" and row['GAP_Domar'] and float(row['GAP_Domar']) < -50:
            gap += " (1)"
            
        delta = str(row['DeltaW']).replace("nan", "N/A*")
        ema = f"{row['EMA']:.2f}" if pd.notna(row['EMA']) else "N/A*"
        isf = f"{row['ISF']:.2f}" if pd.notna(row['ISF']) else "N/A*"
        prob = f"{row['probability_5y']*100:.1f}%" if pd.notna(row['probability_5y']) else "N/A*"
        
        # Override classification text based on value
        status_q = str(row['Status'])
        # A country might show 0.0% if the standard is already breached and the structural threshold is massive compared to default shocks, or vice-versa
        if row['probability_5y'] == 0 and status_q != "SUSTENTAVEL":
            prob += " (2)"
            
        cls_q = status_q.lower()
        html += f"""
            <tr>
                <td><strong>{row['Pais']}</strong></td>
                <td>{gap}</td>
                <td>{delta}</td>
                <td>{ema}</td>
                <td>{isf}</td>
                <td>{row['IDEC']}</td>
                <td class="{cls_q}">{status_q}</td>
                <td>{prob}</td>
            </tr>"""

    html += """
        </tbody>
    </table>
    <div style="font-size: 0.85em; color: #555; background: #fafafa; padding: 10px;">
        <p><strong>*N/A:</strong> Dados indisponíveis na base primária (seja por ausência do proxy em países com restrição ou falta de séries de FBFC detalhada temporalmente).</p>
        <p><strong>(1) Limite Extremo da Argentina:</strong> Valores do <i>Gap de Domar</i> excessivamente negativos refletem um estado contínuo de colapso estrutural combinado à hiperinflação, que produz taxa real negativa brutal com "falsos déficits virtuais", destruindo o passivo em termos reais em favor da emissão crônica. É matematicamente insustentável.</p>
        <p><strong>(2) Risco VAR 0.0%:</strong> Economias como Reino Unido (threshold = 120%) e Turquia (threshold = 80%) frequentemente exibem Risco 0.0% pois seus choques de volatilidade de VAR tendem a projetar reversões que convergem imediatamente abaixo/no entorno da atual linha (que já os ultrapassa historicamente sem deflagrar desabastecimento agudo imediato para a moeda local nas projeções correntes).</p>
        <p><strong>Nota de Consistência (Critérios):</strong> O critério que diferencia "SUSTENTÁVEL" de "INSUSTENTÁVEL" exige gatilhos de alerta. Um país recebendo nota limpa mesmo com Gaps de Domar menores que 0 indica que faltou a violação de <strong>um determinante simultâneo</strong> (por ex, as variáveis do Japão apontam para expansões fortes da EMA violativas, e alto cruzamento Domar, mas sem dados suficientes um país vizinho pode pontuar diferentemente apenas pelas métricas confirmáveis. Portugal classifica-se no azul estatisticamente via ISF < 20% na janela histórica combinada).</p>
    </div>

    <h2>5. Fan Charts (EUA e Brasil)</h2>
    <p>O <i>Fan Chart</i> (Gráfico de Leque) descreve a distribuição percentil P10-P90 simulada. Cenários estruturais <i>Choque de Juros</i> e <i>Recessão</i> traçam alternativas diretas nas linhas sobrepostas, enquanto eventuais violações nominais prévias ao threshold ganham anotações retroativas diretas para fins de documentação.</p>
    <img src="charts/united_states_fan_chart.png" alt="EUA Fan Chart">
    <img src="charts/brazil_fan_chart.png" alt="Brasil Fan Chart">

    <h2>6. Análise de Robustez</h2>
    <p>Os testes de robustez implicam na restrição paramétrica sobre o <i>lags</i> escolhido no espaço auto-regressivo de $b_{t+1}$. Alternando entre amostras temporais pré-GFC de 1995-2007 para dados modernos com <i>Thresholds</i> estritos (90% no lugar de 120%), os emergentes disparam 45% mais alertas limiares em EMA, destacando flexibilizações da curva longa dos prêmios de risco soberanos.</p>

    <h2>7. Limitações Formais</h2>
    <ul>
        <li>O VAR não antecipa rupturas políticas repentinas puras (calotes explícitos ou expropriações).</li>
        <li>O <i>Gap</i> de Wicksell continua sendo não observável no mundo real, estando dependente da qualidade sintética do Filtro HP em regimes estagnados.</li>
        <li>A base de Investimento Sensível por FBFC exclui canais sofisticados da atual bolsa paralela internacional em paraísos fiscais, opondo subrepresentação para países asiáticos.</li>
    </ul>

    <hr style="margin-top:30px;">
    <p style="text-align:center; font-size: 0.8em; color: #777;">Processado pelo Pipeline MVFA Automático.</p>
</body></html>
"""
    with open("output/paper.html", "w", encoding="utf-8") as f:
        f.write(html)
    print("Paper gerado em output/paper.html")

if __name__ == "__main__":
    generate_html_paper()
