            gdp = frame["gdp_real_growth"].replace([np.inf, -np.inf], np.nan).fillna(method="ffill").fillna(method="bfill")
            if len(gdp.dropna()) > 5:
                cycle2, gdp_trend = sm.tsa.filters.hpfilter(gdp.dropna(), 100)
                result.loc[result["country"] == country, "natural_rate_gdp_trend"] = gdp_trend.reindex(gdp.index).values
        except Exception:
            pass
    return result
""")
    else:
        new_lines.append(line)

with open("models/rstar.py", "w") as f:
    f.writelines(new_lines)
